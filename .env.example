# DASHSCOPE_API_KEY: Required for Alibaba Cloud Model Studio / DashScope API calls.
DASHSCOPE_API_KEY="YOUR_DASHSCOPE_API_KEY"

# DASHSCOPE_BASE_URL: Optional override for region-specific compatible-mode endpoint.
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# DASHSCOPE_MODEL: Optional override for the chat model used by the AI assistant.
DASHSCOPE_MODEL="qwen3.5-plus"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
